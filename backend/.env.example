# VehicleScan Terminal — Backend Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env file to git.

# ── Required ─────────────────────────────────────────────────────────
MONGO_URI=Your MongoDB connection string
SHRINKEARN_API_KEY=Your link shortener API key
VEHICLE_API_BASE=Your upstream API URL (e.g. https://api.example.com)

# ── Optional ──────────────────────────────────────────────────────────
# Set to "development" for verbose logging and debug mode
FLASK_ENV=production

# Port to listen on (Render sets this automatically)
PORT=5000

# Restrict CORS to your production domain (recommended in production)
# Example: ALLOWED_ORIGIN=https://vehicle-scan.onrender.com
ALLOWED_ORIGIN=*
